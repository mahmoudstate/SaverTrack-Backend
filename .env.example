# Copy this file to .env and fill in real values. .env is gitignored.

# Plaid (Sandbox)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/savertrack

# Encryption key for access tokens (generate a strong random 32-byte key)
TOKEN_ENCRYPTION_KEY=

# Server
PORT=3000
